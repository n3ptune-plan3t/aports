pkgname=noctalia
pkgver=5.0.0_beta2
pkgrel=0
pkgdesc="Native Wayland desktop shell"
url="https://github.com/noctalia-dev/noctalia-shell"
arch="all"
license="MIT"
# pipewire daemon is required at runtime (Noctalia aborts if it can't connect)
depends="pipewire"
makedepends="
	build-base
	meson
	samurai
	cairo-dev
	curl-dev
	fontconfig-dev
	freetype-dev
	glib-dev
	harfbuzz-dev
	libqalculate-dev
	librsvg-dev
	libwebp-dev
	libxkbcommon-dev
	libxml2-dev
	linux-pam-dev
	mesa-dev
	md4c-dev
	nlohmann-json
	pango-dev
	polkit-dev
	sdbus-cpp-dev
	stb
	tomlplusplus-dev
	wayland-dev
	wayland-protocols
	wireplumber-dev
	"
subpackages="$pkgname-dbg"
source="$pkgname-$pkgver.tar.gz::https://github.com/noctalia-dev/noctalia-shell/archive/refs/tags/v5.0.0-beta2.tar.gz"

builddir="$srcdir"/noctalia-5.0.0-beta2

prepare() {
	default_prepare

	# Personal build: pin to znver1 instead of -march=native (fails to
	# autodetect inside abuild-rootbld's sandbox).
	sed -i \
		-e "s/-march=native/-march=znver1/g" \
		-e "s/-mtune=native/-mtune=znver1/g" \
		"$builddir"/meson.build

	# Alpine's stb package installs headers flat (/usr/include/stb_*.h)
	# instead of nested under stb/ like most other distros (Debian's
	# libstb-dev, etc). noctalia's meson.build expects the nested layout
	# (#include <stb/stb_image_resize2.h>), so build a compat shim dir
	# with symlinks and expose it via CPATH.
	mkdir -p "$srcdir"/stb-compat/stb
	for h in /usr/include/stb_*.h; do
		ln -sf "$h" "$srcdir"/stb-compat/stb/"$(basename "$h")"
	done
}

build() {
	export CPATH="$srcdir/stb-compat${CPATH:+:$CPATH}"

	meson setup \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--localstatedir=/var \
		--buildtype=release \
		-Dtests=disabled \
		-Djemalloc=disabled \
		output "$builddir"
	meson compile -C output
}

check() {
	meson test --no-rebuild -C output
}

package() {
	DESTDIR="$pkgdir" meson install --no-rebuild -C output
}

sha512sums="
